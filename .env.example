##############################################
# MyR - Root .env example (no secrets)       #
##############################################

# ─── Database Configuration ────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=myrtest
# Use service name "postgres" for Docker; use localhost if running Prisma CLI from host
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/myrtest?schema=public

# ─── Application Configuration ────────────────────────────────────────────────
NODE_ENV=development

# Shared secret for the Admin API (must match admin_frontend VITE_ADMIN_SECRET)
ADMIN_SECRET=change_me_admin_secret

# ─── JWT Configuration ────────────────────────────────────────────────────────
# Long, random secret used to sign JWTs (Bearer tokens)
JWT_SECRET=change_me_jwt_secret
JWT_EXPIRES_IN=8h

# ─── Better Auth Configuration ────────────────────────────────────────────────
# Long, random secret for Better Auth cookie/session encryption
BETTER_AUTH_SECRET=change_me_better_auth_secret

# Public base URL where the backend is reachable (behind nginx)
BETTER_AUTH_URL=http://localhost

# Comma-separated origins allowed for Better Auth (admin app, etc.)
TRUSTED_ORIGINS=http://localhost:5174,http://127.0.0.1:5174,http://localhost:8080,http://127.0.0.1:8080

# ─── OAuth Providers (Optional) ───────────────────────────────────────────────
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# ─── Email Service (SendGrid 2FA) ─────────────────────────────────────────────
# Replace with a real key from https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=your_sendgrid_api_key_here

# Must be a verified sender in your SendGrid account
SENDGRID_FROM_EMAIL=noreply@example.com

# Shared secret between backend and email_service (use a long random string)
EMAIL_SERVICE_SECRET=change_me_email_service_secret

# Port used by the email service container
EMAIL_SERVICE_PORT=3001

# Internal Docker DNS address used by the backend to reach the email service
EMAIL_SERVICE_URL=http://email_service:3001

